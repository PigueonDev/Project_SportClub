# Copia este archivo como ".env" y reemplaza la IP/puerto por la del backend real.
# Ejemplo si el backend está en otra máquina de tu red local:
# VITE_API_URL=http://192.168.1.50:3000/api
#
# Ejemplo si el backend corre en tu propio PC:
# VITE_API_URL=http://localhost:3000/api

VITE_API_URL=http://localhost:3000/api
